parameters:
    level: 8
    paths:
        - src
    excludePaths:
        - vendor
    bootstrapFiles:
        - vendor/autoload.php
    ignoreErrors: []

    # Security-Gate (security.md) — Standard-Liste aus ekino/phpstan-banned-code
    # plus die in unserer security.md zusaetzlich verbotenen Funktionen.
    banned_code:
        nodes:
            - { type: Stmt_Echo, functions: null }
            - { type: Expr_Eval, functions: null }
            - { type: Expr_Exit, functions: null }
            - { type: Expr_Print, functions: null }
            - { type: Expr_ShellExec, functions: null }
            -
                type: Expr_FuncCall
                functions:
                    - dd
                    - debug_backtrace
                    - dump
                    - exec
                    - passthru
                    - phpinfo
                    - print_r
                    - proc_open
                    - shell_exec
                    - system
                    - var_dump
                    # security.md-Erweiterung:
                    - error_log    # Nutze PSR-3 Logger
                    - extract      # Unkontrollierte Variablen
                    - md5          # Nicht kryptographisch — password_hash()
                    - mt_rand      # Nicht kryptographisch — random_int()
                    - rand         # Nicht kryptographisch — random_int()
                    - sha1         # Nicht kryptographisch — password_hash()
                    - unserialize  # Object-Injection — json_decode()
        # use_from_tests aus: Test-Code darf gezielt Test-Klassen nutzen
        use_from_tests: false
        # ignoreErrors muss moeglich bleiben fuer dokumentierte Ausnahmen
        non_ignorable: false

includes:
    - vendor/ekino/phpstan-banned-code/extension.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/phpstan/phpstan-deprecation-rules/rules.neon
