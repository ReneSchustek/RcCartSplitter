<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
           http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <!-- Services -->

        <service id="Ruhrcoder\RcCartSplitter\Service\TmmsPayloadReader"/>

        <service id="Ruhrcoder\RcCartSplitter\Service\OrderInputCorrectionService">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="logger"/>
        </service>

        <!-- Subscriber -->

        <service id="Ruhrcoder\RcCartSplitter\Subscriber\TmmsInputCaptureSubscriber">
            <argument type="service" id="request_stack"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="Ruhrcoder\RcCartSplitter\Service\TmmsPayloadReader"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcCartSplitter\Subscriber\OrderInputCorrectionSubscriber">
            <argument type="service" id="order_line_item.repository"/>
            <argument type="service" id="Ruhrcoder\RcCartSplitter\Service\OrderInputCorrectionService"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcCartSplitter\Subscriber\CartDisplayCorrectionSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

    </services>
</container>
