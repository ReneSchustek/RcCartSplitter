{
    "name": "ruhrcoder/rc-cart-splitter",
    "description": "Erzeugt separate Warenkorbpositionen wenn Kundeneingaben (z. B. TMMS) sich unterscheiden",
    "version": "1.2.0",
    "type": "shopware-platform-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "Ruhrcoder",
            "homepage": "https://ruhrcoder.de"
        }
    ],
    "require": {
        "php": "^8.2",
        "shopware/core": "~6.7.0 || ~6.8.0",
        "shopware/storefront": "~6.7.0 || ~6.8.0"
    },
    "autoload": {
        "psr-4": {
            "Ruhrcoder\\RcCartSplitter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ruhrcoder\\RcCartSplitter\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "ekino/phpstan-banned-code": "^2.1",
        "phpstan/phpstan-strict-rules": "^1.6",
        "phpstan/phpstan-deprecation-rules": "^1.2"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:js": "node --test tests/Js/cart-splitter.test.mjs",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint:twig": "php bin/lint-twig.php",
        "lint:xml": "php bin/lint-xml.php",
        "coverage": "vendor/bin/phpunit --coverage-clover coverage.xml --coverage-text --display-warnings",
        "coverage:gate": "php bin/coverage-gate.php",
        "quality": [
            "@cs-check",
            "@lint:xml",
            "@lint:twig",
            "@phpstan",
            "@test"
        ]
    },
    "extra": {
        "shopware-plugin-class": "Ruhrcoder\\RcCartSplitter\\RcCartSplitter",
        "label": {
            "de-DE": "Warenkorb-Positionstrennung",
            "en-GB": "Cart Position Splitter"
        },
        "description": {
            "de-DE": "Erzeugt separate Warenkorbpositionen wenn Kundeneingaben (z. B. aus TmmsProductCustomerInputs) sich unterscheiden. Gleiche Eingaben erhöhen die Menge, unterschiedliche Eingaben erzeugen neue Positionen.",
            "en-GB": "Creates separate cart positions when customer inputs (e.g. from TmmsProductCustomerInputs) differ. Same inputs increase quantity, different inputs create new positions."
        }
    }
}
